# App
APP_ENV=development
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60
# auto = Redis があれば使用、なければメモリキャッシュ（Docker 不要）
CACHE_BACKEND=auto

# Exchange symbols (override per env)
WHITEBIT_SYMBOL=BTC_USDT
WHITEBIT_FUTURES_SYMBOL=BTC_PERP
BINANCE_SYMBOL=BTCUSDT
BYBIT_FUTURES_SYMBOL=BTCUSDT
BYBIT_SPOT_SYMBOL=BTCUSDT
BITGET_SYMBOL=BTCUSDT
BITGET_FUTURES_SYMBOL=BTCUSDT
OKX_FUTURES_SYMBOL=BTC-USDT-SWAP
COINBASE_SYMBOL=BTC-USD

# Baseline exchange for divergence
BASELINE_EXCHANGE=whitebit

# Coinglass（有料・任意）/ 無料は Binance Futures を使用
COINGLASS_API_KEY=
# 経済指標カレンダー（無料登録）https://finnhub.io/
FINNHUB_API_KEY=
# free | coinglass | auto  （既定: free = APIキー不要）
DERIVATIVES_PROVIDER=free
# 先物データを取得する取引所（カンマ区切り）
DERIVATIVES_EXCHANGES=binance,bybit,okx,whitebit,bitget

# LLM (Phase 4) — Gemini or Anthropic
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite
ANTHROPIC_API_KEY=

# Internal collect endpoint (Cloud Scheduler)
INTERNAL_COLLECT_TOKEN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Invite-only access (API + frontend gate)
INVITE_ONLY=false
ALLOWED_EMAILS=
# Temporary: allow any Google account to sign in (set false to re-enable invite gate)
AUTH_OPEN_GOOGLE=true

# Invite emails via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_PUBLIC_URL=https://nexus-btc-trading.web.app

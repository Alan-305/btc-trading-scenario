{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "Debug Current Test",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v", "${file}"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "API + Frontend",
      "configurations": ["Debug API (FastAPI)"],
      "preLaunchTask": "frontend: dev",
      "presentation": {
        "group": "dev",
        "order": 1
      }
    }
  ]
}
